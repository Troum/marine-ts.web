NUXT_PUBLIC_API_BASE=http://localhost:8000/api

# Скрыть карточки на главной админки /admin и пункты в модалке «Выберите раздел» (публичный сайт не трогает).
# Ключи: application_forms, vacancies, news, gallery, projects, about, services, ship_management, crewing_management, lnk, contacts, home,
# inquiries, feedback, section_editor, content_pages, sections_panel, appearance, navigation, footer_navigation, users, seo
# NUXT_PUBLIC_ADMIN_HIDDEN_SECTIONS=vacancies,news,gallery,projects

# Опционально: внешняя аналитика (только публичный сайт; не /admin). Если задан GA4 — Plausible не грузится.
# NUXT_PUBLIC_ANALYTICS_GTAG_ID=G-XXXXXXXX
# NUXT_PUBLIC_ANALYTICS_PLAUSIBLE_DOMAIN=example.com

# Яндекс.Метрика (счётчик со старого сайта)
NUXT_PUBLIC_YANDEX_METRIKA_ID=86888216

