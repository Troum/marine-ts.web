# ── Локальная разработка ─────────────────────────────────────────────────────
# NUXT_PUBLIC_API_BASE=
# NUXT_API_BASE_SERVER=
# NUXT_PUBLIC_SITE_URL=http://localhost:3000
# NUXT_API_ORIGIN=http://marine-ts.test

# ── Продакшен (пример для сервера /var/www/marin-ts.com) ───────────────────
NUXT_PUBLIC_API_BASE=https://api.marin-ts.com/api
NUXT_API_BASE_SERVER=https://api.marin-ts.com/api
NUXT_PUBLIC_SITE_URL=https://marin-ts.com
# NUXT_API_ORIGIN — только для dev (Vite proxy на Laravel). В проде не нужен.
# NUXT_API_ORIGIN=https://api.marin-ts.com

# Скрыть разделы в админке (карточки на /admin и модалка «Выберите раздел»).
# Ключи: application_forms, vacancies, news, gallery, projects, about, services,
# ship_management, crewing_management, lnk, contacts, home, inquiries, feedback,
# section_editor, content_pages, sections_panel, appearance, navigation,
# footer_navigation, users, seo
NUXT_PUBLIC_ADMIN_HIDDEN_SECTIONS=vacancies,news,gallery,projects

# Яндекс.Метрика — задать до npm run build
NUXT_PUBLIC_YANDEX_METRIKA_ID=86888216

# Опционально: GA4 / Plausible (только публичный сайт; не /admin)
# NUXT_PUBLIC_ANALYTICS_GTAG_ID=G-XXXXXXXX
# NUXT_PUBLIC_ANALYTICS_PLAUSIBLE_DOMAIN=example.com

# NUXT_PUBLIC_MAPBOX_TOKEN=
# NUXT_PUBLIC_YANDEX_MAPS_API_KEY=
